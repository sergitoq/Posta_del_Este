<script>
  const burger = document.getElementById('burger');
  const navLinks = document.getElementById('navLinks');
  burger.addEventListener('click', () => navLinks.classList.toggle('open'));
  navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navLinks.classList.remove('open')));
  const io = new IntersectionObserver(e => e.forEach(x => { if(x.isIntersecting){ x.target.style.opacity='1'; x.target.style.transform='translateY(0)'; }}), {threshold:0.1});
  document.querySelectorAll('.amenity-item').forEach(el => { el.style.cssText+='opacity:0;transform:translateY(16px);transition:opacity .4s ease,transform .4s ease'; io.observe(el); });
</script>
</body>
</html>
